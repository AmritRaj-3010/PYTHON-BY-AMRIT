# Program 4: Delete files inside a folder
# User enters folder name, program deletes all files inside it
import os

folder = input("Enter folder name: ")

try:
    files = os.listdir(folder)
    for fname in files:
        path = os.path.join(folder, fname)
        if os.path.isfile(path):
            os.remove(path)
            print(f" Deleted {path}")
    print(f" All files in {folder} deleted.")
except FileNotFoundError:
    print(" Folder not found!")

# output:
# Enter folder name: abhay
#  Deleted abhay\chaman
#  All files in abhay deleted.




# Program 5: Safe delete with confirmation
# Asks user before deleting the file
import os

filename = input("Enter filename to delete: ")

if os.path.exists(filename):
    confirm = input(f" Are you sure you want to delete '{filename}'? (yes/no): ")
    if confirm.lower() == "yes":
        os.remove(filename)
        print(f" File '{filename}' deleted.")
    else:
        print(" Deletion cancelled.")
else:
    print(" File not found!")


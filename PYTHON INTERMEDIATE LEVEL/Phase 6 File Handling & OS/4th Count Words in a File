# Program 1: Count total words in a file
# User enters filename, program counts all words
filename = input("Enter filename: ")

try:
    with open(filename, "r") as f:
        text = f.read()
        words = text.split()
        print(" Total words:", len(words))
except FileNotFoundError:
    print(" File not found!")

# output:
# Enter filename: amrit.bin
#  Total words: 0






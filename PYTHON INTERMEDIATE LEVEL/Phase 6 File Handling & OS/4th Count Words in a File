# Program 4: Count frequency of each word
# User enters filename, program shows word frequency
filename = input("Enter filename: ")

try:
    with open(filename, "r") as f:
        text = f.read().lower()
        words = text.split()
        freq = {}
        for w in words:
            freq[w] = freq.get(w, 0) + 1
        print(" Word frequencies:")
        for word, count in freq.items():
            print(f"{word}: {count}")
except FileNotFoundError:
    print(" File not found!")

# output:
# Enter filename: aman.bin
#  Word frequencies:
# ---: 2
# appended: 1
# content: 1






# Program 5: Count occurrences of a specific word
# User enters filename and word, program counts how many times it appears
filename = input("Enter filename: ")
search_word = input("Enter word to search: ").lower()

try:
    with open(filename, "r") as f:
        text = f.read().lower()
        words = text.split()
        count = words.count(search_word)
        print(f" The word '{search_word}' appears {count} times.")
except FileNotFoundError:
    print(" File not found!")

# output:
# Enter filename: amrit.bin
# Enter word to search: am
#  The word 'am' appears 2 times.
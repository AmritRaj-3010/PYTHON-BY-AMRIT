# Program 1: Merge two files into a new file
# User enters two source files and one destination file
file1 = input("Enter first filename: ")
file2 = input("Enter second filename: ")
dest = input("Enter destination filename: ")

try:
    with open(file1, "r") as f1, open(file2, "r") as f2, open(dest, "w") as f3:
        f3.write(f1.read())
        f3.write("\n")
        f3.write(f2.read())
    print(f" Merged {file1} and {file2} into {dest}")
except FileNotFoundError:
    print(" One of the files not found!")

# output:
# Enter first filename: amrit.bin
# Enter second filename: ansh.bin
# Enter destination filename: aman.bin
#  Merged amrit.bin and ansh.bin into aman.bin





# Program 2: Merge line by line
# Reads both files line by line and writes them alternately
file1 = input("Enter first filename: ")
file2 = input("Enter second filename: ")
dest = input("Enter destination filename: ")

try:
    with open(file1, "r") as f1, open(file2, "r") as f2, open(dest, "w") as f3:
        for line1, line2 in zip(f1, f2):
            f3.write(line1.strip() + " " + line2)
    print(f" Line-by-line merge done into {dest}")
except FileNotFoundError:
    print(" One of the files not found!")

# output:
# Enter first filename: amrit.bin
# Enter second filename: ansh.bin
# Enter destination filename: aman.bin
#  Line-by-line merge done into aman.bin






# Program 3: Merge with separator
# Adds a custom separator between contents of two files
file1 = input("Enter first filename: ")
file2 = input("Enter second filename: ")
dest = input("Enter destination filename: ")
sep = input("Enter separator text: ")

try:
    with open(file1, "r") as f1, open(file2, "r") as f2, open(dest, "w") as f3:
        f3.write(f1.read())
        f3.write(f"\n{sep}\n")
        f3.write(f2.read())
    print(f" Merged with separator into {dest}")
except FileNotFoundError:
    print(" One of the files not found!")

# output:
# Enter first filename: amrit.bin
# Enter second filename: ansh.bin
# Enter destination filename: aman.bin
# Enter separator text: ::
#  Merged with separator into aman.bin







# Program 4: Merge multiple files chosen by user
# User enters filenames separated by space, program merges all
files = input("Enter filenames separated by space: ").split()
dest = input("Enter destination filename: ")

try:
    with open(dest, "w") as f_out:
        for fname in files:
            with open(fname, "r") as f_in:
                f_out.write(f_in.read())
                f_out.write("\n--- End of File ---\n")
    print(f" Merged {len(files)} files into {dest}")
except FileNotFoundError as e:
    print(f" File not found: {e.filename}")

# output:
# Enter filenames separated by space: amrit.bin
# Enter destination filename: aman.bin
#  Merged 1 files into aman.bin







# Program 5: Merge only unique lines from two files
# Avoids duplicate lines when merging
file1 = input("Enter first filename: ")
file2 = input("Enter second filename: ")
dest = input("Enter destination filename: ")

try:
    lines = set()
    with open(file1, "r") as f1, open(file2, "r") as f2:
        lines.update(f1.readlines())
        lines.update(f2.readlines())
    with open(dest, "w") as f3:
        f3.writelines(lines)
    print(f" Merged unique lines into {dest}")
except FileNotFoundError:
    print(" One of the files not found!")

# output:
# Enter first filename: amrit.bin
# Enter second filename: ansh.bin
# Enter destination filename: aman.bin
#  Merged unique lines into aman.bin




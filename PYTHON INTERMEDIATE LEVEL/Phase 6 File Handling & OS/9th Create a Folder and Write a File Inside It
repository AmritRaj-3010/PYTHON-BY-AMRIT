# Program 4: Write multiple lines into a file inside folder
# User enters folder, file, and multiple lines
# Program 4: Write multiple lines into a file inside folder (safe version)
import os

folder = input("Enter folder name: ")
filename = input("Enter file name (e.g., notes.txt): ")

#  Ensure folder exists
os.makedirs(folder, exist_ok=True)

path = os.path.join(folder, filename)

#  Prevent error if a folder already exists with same name
if os.path.isdir(path):
    print(f"❌ Cannot create file '{filename}' because a folder with that name exists.")
else:
    print("Enter lines (type 'STOP' to finish):")
    lines = []
    while True:
        line = input()
        if line.strip().lower() == "stop":   # accepts STOP, stop, Stop
            break
        lines.append(line + "\n")

    with open(path, "w") as f:
        f.writelines(lines)

    print(f" File '{filename}' created with {len(lines)} lines inside '{folder}'")

# output:
# Enter folder name: angad
# Enter file name (e.g., notes.txt): bin.txt
# Enter lines (type 'STOP' to finish):
# i am amrit
# i am ansh
# i am ananya
# i am ankit
# STOP
#  File 'bin.txt' created with 4 lines inside 'angad'






# Program 5: Confirm file creation by listing folder contents
# User enters folder name, program lists all files inside
import os

folder = input("Enter folder name: ")

if os.path.exists(folder):
    print(f" Files inside '{folder}':")
    for f in os.listdir(folder):
        print(f)
else:
    print(" Folder not found!")


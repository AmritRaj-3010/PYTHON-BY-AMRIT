# Program 1: Create a new folder
# User enters folder name, program creates it
import os

folder = input("Enter folder name to create: ")

try:
    os.mkdir(folder)
    print(f" Folder '{folder}' created successfully.")
except FileExistsError:
    print(" Folder already exists!")

# output:
# Enter folder name to create: amrit
#  Folder 'amrit' created successfully.






# Program 2: Create folder and write a file inside it
# User enters folder name and file name, program creates both
import os

folder = input("Enter folder name: ")
filename = input("Enter file name (e.g., notes.txt): ")
content = input("Enter content to write in the file: ")

os.makedirs(folder, exist_ok=True)  # create folder if not exists
path = os.path.join(folder, filename)

with open(path, "w") as f:
    f.write(content)

print(f" File '{filename}' created inside folder '{folder}'")

# output:
# Enter folder name: ansh
# Enter file name (e.g., notes.txt): .bin
# Enter content to write in the file: ansh is younger brother of amrit
#  File '.bin' created inside folder 'ansh'






# Program 3: Create nested folders and file
# User enters folder path and file name, program creates nested structure
# Safe folder creation with file check
import os

folder_path = input("Enter folder path (e.g., ansh/bin): ")
filename = input("Enter file name (e.g., notes.txt): ")
content = input("Enter content: ")

#  Create folder only if it doesn't exist
if not os.path.exists(folder_path):
    os.makedirs(folder_path)
    print(f" Folder '{folder_path}' created.")
else:
    print(f" Folder '{folder_path}' already exists.")

#  Create file inside folder
path = os.path.join(folder_path, filename)
with open(path, "w") as f:
    f.write(content)

print(f" File '{filename}' created inside '{folder_path}'")


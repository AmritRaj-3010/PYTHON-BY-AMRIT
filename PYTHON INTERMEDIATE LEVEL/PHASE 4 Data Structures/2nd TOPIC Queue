# Program 1: Simple enqueue & dequeue
from queue import Queue


queue = []
queue.append(10)   # enqueue
queue.append(20)
queue.append(30)
print("Queue after enqueues:", queue)

print("Dequeued element:", queue.pop(0))  # dequeue
print("Queue now:", queue)

# output:
# Queue after enqueues: [10, 20, 30]
# Dequeued element: 10
# Queue now: [20, 30]





# Program 2: User input queue
queue = []
n = int(input("How many elements to enqueue? "))
for i in range(n):
    val = int(input(f"Enter element {i+1}: "))
    queue.append(val)
print("Queue =", queue)

print("Dequeued element:", queue.pop(0))
print("Queue after dequeue:", queue)

# output:
# How many elements to enqueue? 2
# Enter element 1: 3
# Enter element 2: 6
# Queue = [3, 6]
# Dequeued element: 3
# Queue after dequeue: [6]





# Program 3: Check empty queue
queue = []
if not queue:

# Program 1: Simple push & pop
stack = []
stack.append(10)   # push
stack.append(20)
stack.append(30)
print("Stack after pushes:", stack)
print("Popped element:", stack.pop())  # pop
print("Stack now:", stack)

# output:
# Stack after pushes: [10, 20, 30]
# Popped element: 30
# Stack now: [10, 20]



# Program 2: User input stack
stack = []
n = int(input("How many elements to push? "))
for i in range(n):
    val = int(input(f"Enter element {i+1}: "))
    stack.append(val)
print("Stack =", stack)
print("Popped element:", stack.pop())
print("Stack after pop:", stack)

# output:
# How many elements to push? 1
# Enter element 1: 10
# Stack = [10]
# Popped element: 10
# Stack after pop: []




# Program 3: Check empty stack
stack = []
if not stack:
    print("Stack is empty")
else:
    print("Stack has elements:", stack)

# output:
# Stack is empty

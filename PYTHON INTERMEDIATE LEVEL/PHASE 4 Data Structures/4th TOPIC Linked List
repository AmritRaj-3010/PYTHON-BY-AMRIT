# Program 1: Create a simple linked list with 3 nodes
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# Create nodes
head = Node(10)
second = Node(20)
third = Node(30)

# Link nodes
head.next = second
second.next = third

# Traverse and display
temp = head
print("Linked List:", end=" ")
while temp:
    print(temp.data, end=" -> ")
    temp = temp.next

# output:
# Linked List: 10 -> 20 -> 30 -> 




# Program 2: Insert a new node at the beginning
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# Create initial list
head = Node(10)
head.next = Node(20)

# Insert new node at beginning
new_node = Node(5)
new_node.next = head
head = new_node

# Traverse
temp = head
print("Linked List after insertion:", end=" ")
while temp:
    print(temp.data, end=" -> ")
    temp = temp.next

# output:
# Linked List after insertion: 5 -> 10 -> 20 ->






# Program 3: Delete a node by value
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# Create list
head = Node(10)
head.next = Node(20)
head.next.next = Node(30)

# Delete node with value 20
temp = head
prev = None
while temp and temp.data != 20:
    prev = temp
    temp = temp.next

if temp:
    prev.next = temp.next
    print("Node with value 20 deleted")

# Traverse
temp = head
print("Linked List after deletion:", end=" ")
while temp:
    print(temp.data, end=" -> ")
    temp = temp.next

# output:
#  Node with value 20 deleted
# Linked List after deletion: 10 -> 30 ->
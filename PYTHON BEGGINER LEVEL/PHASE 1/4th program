# ALL PROGRAMS ARE WRITTEN ON THE DIFFICULTY LEVELS OF THE FACTORIAL SERIES 
# ALL PROGRAMS ARE WRITTEN IN THE USER INPUT FORMAT 


# Program 1: Using loop
n = int(input("Enter a number: "))
fact = 1
for i in range(1, n+1):
    fact *= i
print("Factorial =", fact)

# #OUTPUT:
# Enter a number: 4
# Factorial = 24





# Program 2: Using recursion
def factorial(n):
    if n == 0 or n == 1:
        return 1
    return n * factorial(n-1)
print("Factorial =", factorial(int(input("Enter a number: "))))

#OUTPUT:
# Enter a number: 15
# Factorial = 1307674368000 







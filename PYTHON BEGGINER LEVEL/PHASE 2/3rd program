# Program 2: Frequency of each word
sentence = input("Enter a sentence: ")
freq = {}
for word in sentence.split():
    freq[word] = freq.get(word, 0) + 1
print("Word frequencies:", freq)

# OUTPUT :
# Enter a sentence: I AM ANANYA KUMARI FROM CLASS 9TH C
# Word frequencies: {'I': 1, 'AM': 1, 'ANANYA': 1, 'KUMARI': 1, 'FROM': 1, 'CLASS': 1, '9TH': 1, 'C': 1}





# Program 3: Most frequent word
sentence = input("Enter a sentence: ")
freq = {}
for word in sentence.split():
    freq[word] = freq.get(word, 0) + 1
max_word = max(freq, key=freq.get)
print("Most frequent word =", max_word)

# OUTPUT :
# Enter a sentence: NIDHI IS A GIRL WHO LOVES TO VISIT GARDEN AND OBSERVE FLOWERS 
# Most frequent word = NIDHI





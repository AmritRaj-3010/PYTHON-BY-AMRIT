# Program 3: Length of each word
sentence = input("Enter a sentence: ")
words = sentence.split()
for w in words:
    print(w, "->", len(w))

# OUTPUT: 
# Enter a sentence: AWANI IS MAD 
# AWANI -> 5
# IS -> 2
# MAD -> 3
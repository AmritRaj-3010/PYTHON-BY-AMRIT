# ALL THE 3 CODES ARE WRITTEN ON THE DIFFICULTY LEVELS IN WRITTING THE PROGRAM
# ALL THE 3 CODES ARE WRITTEN IN THE USER FRIENDLY FORMATE


# Program 1: Second largest using sort
nums = list(map(int, input("Enter numbers: ").split()))
nums.sort()
print("Second largest =", nums[-2])

# OUTPUT:
# Enter numbers: 2 5 7 9 54 32 1 1 4
# Second largest = 32




# Program 2: Second largest without sort
nums = list(map(int, input("Enter numbers: ").split()))
first = second = float('-inf')
for n in nums:
    if n > first:
        second, first = first, n
    elif n > second and n != first:
        second = n
print("Second largest =", second)

# OUTPUT:
# Enter numbers: 3 8 5 3 1  56 8 6 4 3 
# Second largest = 8





# Program 3: Second largest string by length
words = input("Enter words: ").split()
words.sort(key=len)
print("Second longest word =", words[-2])

# OUTPUT:
# Enter words: ABHAY ANSH ACHAL ANKIT AROV
# Second longest word = ACHAL





